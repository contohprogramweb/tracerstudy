*.php.swp

# Environment
.env
.env.local
.env.*

# Logs
*.log
application/logs/*

# Cache and temporary files
__pycache__/
*.pyc
*.pyo
*.pyd
.PythonCache/
.php_cs.cache
.phpunit.result.cache

# Dependencies
vendor/
node_modules/
bower_components/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
.directory
*.nfs*

# Build and distribution
dist/
build/
target/
coverage/
htmlcov/
.coverage

# Database
*.sql
*.dump
*.dmp

# Compression archives
*.zip
*.tar
*.gz
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
```