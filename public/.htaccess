# Apache .htaccess for CodeIgniter 3 HMVC
# Compatible: Apache 2.4 + XAMPP (Windows & Linux)
# PERBAIKAN: Ganti sintaks Apache 2.2 (Order/Allow/Deny) 
#            ke Apache 2.4 (Require) - XAMPP modern pakai Apache 2.4

# ============================================================
# URL REWRITING
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # PENTING untuk XAMPP: sesuaikan RewriteBase dengan path instalasi.
    # Jika aplikasi di: http://localhost/tracerstudy/  -> RewriteBase /tracerstudy/public/
    # Jika aplikasi di: http://localhost/              -> RewriteBase /
    # Jika pakai VirtualHost (domain sendiri)         -> RewriteBase /
    RewriteBase /tracerstudy/public/

    # Jangan rewrite request ke file/folder yang sudah ada (assets, dll)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Semua request diteruskan ke index.php
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Disable directory listing
Options -Indexes

# ============================================================
# FILE ACCESS RESTRICTIONS (Apache 2.4 syntax)
# ============================================================

# Blok akses ke file tersembunyi (diawali titik: .env, .git, dll)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Blok akses ke file sensitif
<FilesMatch "\.(env|sql|log|ini|sh|bat|md|rst|txt|json|lock|xml|gitignore|htpasswd)$">
    Require all denied
</FilesMatch>

# ============================================================
# UPLOAD DIRECTORY PROTECTION
# ============================================================
# Cegah eksekusi PHP di folder uploads
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|phps|cgi|pl|py)$ - [F,L]
</IfModule>

# ============================================================
# CACHE CONTROL UNTUK STATIC ASSETS
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg          "access plus 1 year"
    ExpiresByType image/jpeg         "access plus 1 year"
    ExpiresByType image/gif          "access plus 1 year"
    ExpiresByType image/png          "access plus 1 year"
    ExpiresByType image/svg+xml      "access plus 1 year"
    ExpiresByType image/webp         "access plus 1 year"
    ExpiresByType text/css           "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2         "access plus 1 year"
    ExpiresByType application/pdf    "access plus 1 month"
</IfModule>

# ============================================================
# GZIP COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE text/xml application/xml text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================================
# PHP SETTINGS (XAMPP)
# ============================================================
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
<IfModule mod_php8.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
